{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    },
    "//": "Explicit targets so the CSS minifier keeps the standard (unprefixed) backdrop-filter alongside the -webkit- one. Firefox has no -webkit-backdrop-filter, which forces the standard property into the built output.",
    "browserslist": [
        "last 2 Chrome versions",
        "last 2 Edge versions",
        "last 2 Firefox versions",
        "Firefox ESR",
        "last 2 Safari versions",
        "last 2 iOS versions",
        "not dead"
    ]
}
